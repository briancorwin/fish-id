[FORMAT]
max-line-length=130

[DESIGN]
max-locals=30
max-args=8
max-positional-arguments=8
max-returns=10

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    global-statement

[TYPECHECK]
# cv2 uses pybind11 dynamic attributes; treat all cv2.* members as generated
generated-members=cv2.*,cv2.dnn.*
